# Copy to .env.local and fill in your own values. .env.local is gitignored.
#
# The Miaoda full_stack app id (from the Feishu 妙搭/aPaaS console).
COPILOT_BRIDGE_APP_ID=
# lark-cli profile authorized for the app (spark:app:read/write).
COPILOT_BRIDGE_PROFILE=hermes
# Which DB environment the released app reads. Almost always "online".
COPILOT_BRIDGE_DB_ENV=online
# Comma-separated app-scoped user_id values allowed to send commands.
# Find yours by sending one message from Feishu, then on the server run:
#   python -m bridge events --session <id>   (or query the commands table)
#   SELECT DISTINCT sender_open_id FROM commands WHERE result LIKE 'forbidden%';
COPILOT_BRIDGE_ALLOW_OPEN_IDS=

# tmux keys used to drive a live Codex TUI session. Per Codex's default keymap
# (codex-rs/tui/src/keymap.rs), composer.submit = Enter and editor.insert_newline
# includes Ctrl+J — so Enter submits the draft and C-j inserts a newline.
COPILOT_BRIDGE_CODEX_SUBMIT_KEY=Enter
COPILOT_BRIDGE_CODEX_NEWLINE_KEY=C-j
