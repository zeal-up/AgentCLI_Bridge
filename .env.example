# Copy to .env.local and fill in your own values. .env.local is gitignored.
#
# The Miaoda full_stack app id (from the Feishu 妙搭/aPaaS console).
COPILOT_BRIDGE_APP_ID=
# lark-cli profile authorized for the app (spark:app:read/write).
COPILOT_BRIDGE_PROFILE=hermes
# Which DB environment the released app reads. Almost always "online".
COPILOT_BRIDGE_DB_ENV=online
# Comma-separated app-scoped user_id values allowed to send commands.
# Find yours by sending one message from Feishu, then on the server run:
#   python -m bridge events --session <id>   (or query the commands table)
#   SELECT DISTINCT sender_open_id FROM commands WHERE result LIKE 'forbidden%';
COPILOT_BRIDGE_ALLOW_OPEN_IDS=

# tmux keys used to drive a live Codex TUI session. Per Codex's default keymap
# (codex-rs/tui/src/keymap.rs), composer.submit = Enter and editor.insert_newline
# includes Ctrl+J — so Enter submits the draft and C-j inserts a newline.
COPILOT_BRIDGE_CODEX_SUBMIT_KEY=Enter
COPILOT_BRIDGE_CODEX_NEWLINE_KEY=C-j

# ---- Streaming voice input relay (optional, OFF by default) ----
# Voice is OFF unless both VOICE_ASR_BACKEND and VOICE_RELAY_SECRET are set.
# See docs/voice.md (or the plan) for the full setup including the
# cloudflared tunnel. The page falls back to the browser Web Speech API
# when voice is off or unreachable.
#
# ASR backend: none (off) | echo (risk-gate test) | dashscope (cloud) |
#   funasr (local GPU, self-hosted). echo/dashscope/funasr require SECRET.
COPILOT_BRIDGE_VOICE_ASR_BACKEND=none
# Shared HMAC secret with the Miaoda app (set VOICE_RELAY_SECRET there to the
# SAME value). The page gets a short-lived token from GET /api/voice/config;
# the relay verifies it and checks the embedded userId against
# COPILOT_BRIDGE_ALLOW_OPEN_IDS. Generate one with: python -c "import secrets;print(secrets.token_urlsafe(32))"
COPILOT_BRIDGE_VOICE_RELAY_SECRET=
# Local port the relay listens on (cloudflared forwards here). Default 8765.
COPILOT_BRIDGE_VOICE_RELAY_PORT=8765
# Only for dashscope: 阿里百炼 API key (server-side only, never reaches the browser).
COPILOT_BRIDGE_DASHSCOPE_API_KEY=
# Only for funasr: local FunASR streaming server URL. Default assumes the
# GPU FunASR server runs on this same machine.
COPILOT_BRIDGE_FUNASR_WSS_URL=ws://localhost:10095
