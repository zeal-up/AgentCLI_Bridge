# --- Python (bridge) ---
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
.venv/
venv/
.mypy_cache/
.ruff_cache/

# --- Miaoda app: live build/push working dir (private, not open-sourced) ---
# app/ is also the Miaoda git working tree (pushes to miaoda-git.feishu.cn).
# Its .git is a gitfile pointer to .app-git/ (the actual repo data), so the
# outer open-source repo still tracks app/ SOURCE files.
.app-git/
app/.git
app/node_modules/
app/dist/
app/build/
app/logs/
app/tmp/
app/.eslintcache
app/*.tsbuildinfo
# Miaoda platform / scaffold private dirs
app/.agents/
app/.claude/
app/.spark
app/.spark_project
app/.githooks/
app/.env
app/.env.local
app/.env.*.local

# --- Environment / secrets (never commit) ---
.env
.env.local
.env.*.local
*.pem
*.key

# --- Local bridge state (sqlite, logs, pids) ---
bridge-state.db
*.db
*.db-journal
logs/
*.log
pids/
*.pid

# --- Local-only working notes / promotion drafts ---
.local/

# --- Editor / OS ---
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store
Thumbs.db

# --- Agent/IDE local dirs ---
.agent/
.claude/
.agents/
